# ============================================================
# BikeTrip — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer le fichier .env dans Git.
# ============================================================

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-publique

# ATTENTION : ne jamais exposer la service_role key côté mobile
# Cette clé est réservée au backend / Edge Functions
# SUPABASE_SERVICE_ROLE_KEY=NEVER_IN_MOBILE

# --- Météo (Open-Meteo est gratuit et sans clé par défaut) ---
# Pour une API météo alternative avec clé :
# EXPO_PUBLIC_WEATHER_API_KEY=ta-cle-api-meteo
# EXPO_PUBLIC_WEATHER_BASE_URL=https://api.open-meteo.com/v1

# --- App ---
EXPO_PUBLIC_APP_ENV=development
# development | staging | production

EXPO_PUBLIC_APP_VERSION=1.0.0

# --- Stockage images (Supabase Storage) ---
EXPO_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
EXPO_PUBLIC_STORAGE_BUCKET_REPORTS=report-images
EXPO_PUBLIC_STORAGE_BUCKET_RIDES=ride-photos
EXPO_PUBLIC_STORAGE_BUCKET_TRAILS=trail-covers

# --- Limites upload ---
EXPO_PUBLIC_MAX_IMAGE_SIZE_MB=5
EXPO_PUBLIC_MAX_IMAGE_WIDTH=1200

# --- Notifications (Expo Push) ---
# Configuré automatiquement via expo-notifications
# EXPO_PUBLIC_PUSH_TOKEN=automatique

# --- Feature flags ---
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ADMIN_PANEL=false
EXPO_PUBLIC_ENABLE_COMMUNITY_FEATURES=true
